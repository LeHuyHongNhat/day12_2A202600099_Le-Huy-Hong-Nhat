# Cấu hình Port cho ứng dụng
PORT=8000

# URL kết nối Redis (Mặc định dùng trong Docker Compose)
REDIS_URL=redis://redis:6379/0

# Key dùng để xác thực API (Tự đặt)
AGENT_API_KEY=your-secret-key-here

# Key OpenAI thực tế (Bắt buộc để dùng GPT)
OPENAI_API_KEY=sk-xxxx...

# Cấu hình Log
LOG_LEVEL=INFO
ENVIRONMENT=production

# Hạn mức (Dùng cho logic Rate Limit & Cost Guard)
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
